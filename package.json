{
  "name": "food-queue",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute foodqueue-db --local --file=./migrations/0001_init.sql",
    "db:init:remote": "wrangler d1 execute foodqueue-db --remote --file=./migrations/0001_init.sql",
    "pages:dev": "wrangler pages dev --proxy 5173",
    "preview:server": "wrangler pages dev dist --port 8788 --compatibility-flags nodejs_compat",
    "pages:deploy": "npm run build && wrangler pages deploy dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wrangler": "^3.89.0"
  }
}
